# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Required for admin tasks (Email notifications, Webhooks, E2E tests)

# OpenRouter (AI menu extraction)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Site URL (used in payment return URLs)
# Set to your production domain on Vercel
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# PawaPay (payments — enable when ready)
# PAWAPAY_JWT=your-pawapay-jwt
# PAWAPAY_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n..."   # from pawaPay dashboard → Webhooks

# Resend (order email notifications — optional)
# RESEND_API_KEY=re_...                         # from resend.com; also update the "from" address domain

# E2E / Playwright tests
# E2E_TEST_EMAIL=e2e-test@menuzai.test               # defaults to e2e-test@menuzai.test
# E2E_TEST_PASSWORD=TestPassword123!                 # defaults to TestPassword123!
# PLAYWRIGHT_BASE_URL=http://localhost:3000           # defaults to http://localhost:3000
