# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Required for admin tasks (email notifications, webhooks, E2E tests)

# OpenRouter (AI menu extraction)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free   # swap without redeploying

# Anthropic (optional — set in Admin → AI Settings to switch provider)
# ANTHROPIC_API_KEY=sk-ant-...

# Site URL (used in payment callback URLs and emails)
# Set to your production domain on Vercel
NEXT_PUBLIC_SITE_URL=https://menuzaai.com

# PawaPay mobile money payments
# Get your API key from the pawaPay dashboard → Developers → API Keys
# PAWAPAY_API_KEY=your-pawapay-api-key
# PAWAPAY_MODE=sandbox                                  # omit or set to "live" for production
# NEXT_PUBLIC_PAWAPAY_MODE=sandbox                      # mirrors PAWAPAY_MODE — shown as a banner in checkout UI
# PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io/v1    # override if needed; auto-set from PAWAPAY_MODE
# PAWAPAY_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n..."  # from pawaPay dashboard → Webhooks → Public Key

# Resend — order confirmation & plan-upgrade emails (optional)
# Get your API key from resend.com
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=orders@menuzaai.com     # must be a Resend-verified domain

# Cron job authentication — REQUIRED. Cron endpoints return 500 if not set.
# Set to any strong random string (e.g. openssl rand -hex 32).
# Vercel cron calls /api/cron/* with Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=your-random-secret-string

# Push notifications (Web Push / VAPID)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key              # server-side signing
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key  # same value — exposed to browser for subscription
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_CONTACT_EMAIL=admin@your-domain.com

# E2E / Playwright tests
# SUPABASE_SERVICE_ROLE_KEY=   (same as above — used by global-setup.ts to create the test user)
# E2E_TEST_EMAIL=e2e-test@menuzai.test
# E2E_TEST_PASSWORD=TestPassword123!
# PLAYWRIGHT_BASE_URL=http://localhost:3000
